<div class="container">
    <h1 class="title">Hola {{user_name}}, bienvenido a Orion</h1>

    <!-- Imagen local inline -->
    <img src="{{asset('/assets/img/orion-logo.svg')}}" alt="Asset Local">

    <!-- Imagen online inline (puede ser localhost con puerto) -->
    <img src="{{onlineAsset('https://cdn.orion.moonnastd.com/game/cover/1')}}" alt="Asset Remoto">

    <!-- Enlace dinámico -->
    <a href="{{url('/')}}">Ir a Orion</a>
</div>
