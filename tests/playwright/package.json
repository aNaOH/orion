{
  "name": "orion-playwright-tests",
  "version": "1.0.0",
  "description": "Automated tests for Orion platform",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:all",
    "test:all": "node scripts/run-tests.js all",
    "test:namespace": "node scripts/run-tests.js namespace",
    "test:namespaces": "node scripts/run-tests.js list",
    "runner": "node runner/server.js",
    "db:reset": "node scripts/reset-db.js",
    "r2:status": "node manage-r2.js status",
    "r2:create": "node manage-r2.js create",
    "r2:empty": "node manage-r2.js empty",
    "r2:delete": "node manage-r2.js delete",
    "r2:recreate": "node manage-r2.js recreate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.921.0",
    "mysql2": "^3.15.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "typescript": "^5.0.0"
  }
}
