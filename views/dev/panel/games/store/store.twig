{% extends 'layouts/admin.twig' %}

{% set is_dev_panel = true %}
{% set title = 'Editar tienda para ' ~ game.title ~ ' | Orion Dev Panel' %}
{% set panel_title = title %}
{% set prices = [1.99, 2.99, 3.99, 4.99, 5.99, 6.99, 7.99, 8.99, 9.99, 14.99, 19.99, 24.99, 29.99, 39.99, 49.99, 59.99, 69.99, 79.99] %}

{% block styles %}
  <link rel="stylesheet" href="{{ asset('vendor/simplemde/simplemde.orion.css') }}">
{% endblock %}

{% block content %}
  <div class="container mx-auto mt-6 max-w-full px-6">
    <div class="flex items-center justify-between">
      <h1 class="text-xl font-semibold text-alt">Editar tienda para {{ game.title }}</h1>
      <a href="/dev/panel/games/" class="text-gray-400 transition hover:text-alt">Volver</a>
    </div>

    <div class="border-b border-gray-700">
      <nav class="flex space-x-6" id="tabButtons">
        <button
          data-tab="store"
          class="tab-button border-b-2 border-alt py-2 font-medium text-alt transition"
        >
          Página de la tienda
        </button>
        <button
          data-tab="builds"
          class="tab-button border-b-2 border-transparent py-2 font-medium text-gray-400 transition hover:text-alt"
        >
          Compilaciones
        </button>
      </nav>
    </div>

    <div id="tabContent" class="mt-6">
      <div id="store" class="tab-pane block">
        <form id="editGameForm" class="space-y-6">
          <div class="relative">
            <input
              type="text"
              id="title"
              name="title"
              placeholder=" "
              value="{{ game.title }}"
              class="peer w-full rounded-lg border border-gray-600 bg-[#0f172a] px-4 pb-2 pt-6 text-gray-200 outline-none placeholder-transparent focus:border-alt focus:ring-2 focus:ring-alt"
            />
            <label
              for="title"
              class="absolute left-4 top-3 text-sm text-gray-400 transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-base peer-placeholder-shown:text-gray-500 peer-focus:top-2.5 peer-focus:text-sm peer-focus:text-alt"
            >
              Título
            </label>
          </div>

          <div class="relative">
            <input
              type="text"
              id="shortDescription"
              name="shortDescription"
              placeholder=" "
              value="{{ game.short_description }}"
              class="peer w-full rounded-lg border border-gray-600 bg-[#0f172a] px-4 pb-2 pt-6 text-gray-200 outline-none placeholder-transparent focus:border-alt focus:ring-2 focus:ring-alt"
            />
            <label
              for="shortDescription"
              class="absolute left-4 top-3 text-sm text-gray-400 transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-base peer-placeholder-shown:text-gray-500 peer-focus:top-2.5 peer-focus:text-sm peer-focus:text-alt"
            >
              Descripción corta
            </label>
          </div>

          <div>
            <label for="genre" class="mb-2 block font-medium text-gray-300">Género</label>
            <select
              id="genre"
              name="genre"
              class="w-full rounded-lg border border-gray-600 bg-[#0f172a] px-4 py-3 text-gray-200 outline-none focus:border-alt focus:ring-2 focus:ring-alt"
            >
              {% for genre in genres %}
                <option value="{{ genre.id }}" {% if game.genre_id == genre.id %}selected{% endif %}>
                  {{ genre.name }}
                </option>
              {% endfor %}
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <p class="mb-2 block font-medium text-gray-300">Características</p>

            <div class="flex flex-row gap-2">
              <select
                id="featureSelector"
                class="w-full rounded-lg border border-gray-600 bg-[#0f172a] px-4 py-3 text-gray-200 outline-none focus:border-alt focus:ring-2 focus:ring-alt"
              >
                <option value="">Seleccionar característica</option>
                {% for feature in features %}
                  <option value="{{ feature.id }}">{{ feature.name }}</option>
                {% endfor %}
              </select>
              <button type="button" id="addFeatureButton" class="flex w-[25%] items-center justify-center rounded-lg bg-alt px-6 py-3 font-medium text-[#1B2A49] transition hover:opacity-90">Agregar característica</button>
            </div>

            <div id="featuresContainer" class="flex flex-col gap-2">
              {% for gameFeature in game.getFeatures() %}
                <div class="flex items-center gap-2" data-feature-id="{{ gameFeature.id }}">
                  <gradient-chip
                    base-color="{{ gameFeature.tint }}"
                    size="24"
                    icon-path="{{ cdn_url('game/feature', gameFeature.icon) }}"
                    text="{{ gameFeature.name }}"
                    border-radius="8"
                    class="w-full"
                  ></gradient-chip>
                  <button type="button" class="rounded-full bg-red-500 px-2 py-1 text-white hover:bg-red-600" data-feature-id="{{ gameFeature.id }}" onclick="deleteFeature({{ gameFeature.id }})">Eliminar</button>
                </div>
              {% endfor %}
            </div>
          </div>

          <div class="flex items-center gap-2">
            <input
              id="asEditor"
              name="asEditor"
              type="checkbox"
              {% if game.as_editor %}checked{% endif %}
              class="h-4 w-4 accent-alt focus:ring-alt"
            />
            <label for="asEditor" class="font-medium text-gray-300">¿Eres la editora?</label>
          </div>

          <div id="developerNameContainer" class="{% if not game.as_editor %}hidden {% endif %}relative">
            <input
              type="text"
              id="developerName"
              name="developerName"
              placeholder=" "
              value="{{ game.developer_name }}"
              class="peer w-full rounded-lg border border-gray-600 bg-[#0f172a] px-4 pb-2 pt-6 text-gray-200 outline-none placeholder-transparent focus:border-alt focus:ring-2 focus:ring-alt"
            />
            <label
              for="developerName"
              class="absolute left-4 top-3 text-sm text-gray-400 transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-base peer-placeholder-shown:text-gray-500 peer-focus:top-2.5 peer-focus:text-sm peer-focus:text-alt"
            >
              Desarrollador
            </label>
          </div>

          <div>
            <label for="price" class="mb-2 block font-medium text-gray-300">Precio</label>
            <select
              id="price"
              name="price"
              class="w-full rounded-lg border border-gray-600 bg-[#0f172a] px-4 py-3 text-gray-200 outline-none focus:border-alt focus:ring-2 focus:ring-alt"
            >
              <option value="0" {% if game.base_price is null or game.base_price == 0 %}selected{% endif %}>Gratis</option>
              {% for price in prices %}
                <option value="{{ price }}" {% if game.base_price == price %}selected{% endif %}>{{ price|number_format(2, ',', '.') }} €</option>
              {% endfor %}
            </select>
          </div>

          <div>
            <label for="discount" class="mb-2 block font-medium text-gray-300">Descuento</label>
            <div class="flex items-center gap-2">
              <input
                id="discount"
                name="discount"
                type="number"
                min="0"
                max="100"
                step="1"
                value="{{ game.discount * 100 }}"
                class="w-full rounded-lg border border-gray-600 bg-[#0f172a] px-4 py-3 text-gray-200 outline-none focus:border-alt focus:ring-2 focus:ring-alt"
              />
              <span class="font-medium text-gray-400">%</span>
            </div>
          </div>

          <div>
            <label for="description" class="mb-2 block font-medium text-gray-300">Descripción</label>
            <textarea
              id="description"
              name="description"
              rows="8"
              class="w-full rounded-lg border border-gray-600 bg-[#0f172a] px-4 py-3 text-gray-200 outline-none focus:border-alt focus:ring-2 focus:ring-alt"
            >{{ game.description }}</textarea>
          </div>

          <div class="space-y-6">
            <div>
              <label for="coverFile" class="mb-2 block font-medium text-gray-300">Portada (600x900)</label>
              <file-upload id="coverFile" min-image-width="600" max-image-width="600" min-image-height="900" max-image-height="900"></file-upload>
            </div>

            <div>
              <label for="thumbFile" class="mb-2 block font-medium text-gray-300">Miniatura (920x430)</label>
              <file-upload id="thumbFile" min-image-width="920" max-image-width="920" min-image-height="430" max-image-height="430"></file-upload>
            </div>

            <div>
              <label for="iconFile" class="mb-2 block font-medium text-gray-300">Icono (32x32–512x512, cuadrado)</label>
              <file-upload id="iconFile" min-image-width="32" max-image-width="512" min-image-height="32" max-image-height="512" image-aspect-ratio="1:1"></file-upload>
            </div>
          </div>

          <div class="mt-6 flex flex-col gap-3">
            <button
              id="submitButtonEdit"
              type="submit"
              class="flex w-full items-center justify-center gap-2 rounded-lg bg-alt px-6 py-3 font-medium text-[#1B2A49] transition hover:opacity-90"
            >
              <i class="bi bi-arrow-repeat hidden animate-spin" id="spinnerEdit"></i>
              <span>Cambiar</span>
            </button>
            <button
              id="changeVisibility"
              data-status="{{ game.is_public ? 'public' : 'hidden' }}"
              class="{{ game.is_public ? 'bg-yellow-500 hover:bg-yellow-400' : 'bg-green-500 hover:bg-green-400' }} w-full rounded-lg px-6 py-3 font-medium text-[#1B2A49] transition"
            >
              {{ game.is_public ? 'Ocultar' : 'Publicar' }}
            </button>
          </div>
        </form>
      </div>

      <div id="builds" class="tab-pane hidden">
        <form id="buildForm" class="space-y-6" enctype="multipart/form-data">
          <div class="relative">
            <input
              type="text"
              id="version"
              name="version"
              placeholder=" "
              class="peer w-full rounded-lg border border-gray-600 bg-[#0f172a] px-4 pb-2 pt-6 text-gray-200 outline-none placeholder-transparent focus:border-alt focus:ring-2 focus:ring-alt"
            />
            <label
              for="version"
              class="absolute left-4 top-3 text-sm text-gray-400 transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-base peer-placeholder-shown:text-gray-500 peer-focus:top-2.5 peer-focus:text-sm peer-focus:text-alt"
            >
              Versión
            </label>
          </div>

          <div>
            <label for="file" class="mb-2 block font-medium text-gray-300">Compilación</label>
            <input
              id="file"
              name="file"
              type="file"
              accept="application/zip"
              class="w-full text-gray-300 transition file:mr-4 file:rounded-md file:border-0 file:bg-alt file:px-4 file:py-2 file:text-[#1B2A49] hover:file:opacity-90"
            />
          </div>

          <div class="hidden h-2.5 w-full overflow-hidden rounded-full bg-gray-800" id="uploadProgressContainer">
            <div id="uploadProgress" class="h-2.5 w-0 bg-alt transition-all duration-300"></div>
          </div>

          <button
            id="submitButtonBuild"
            type="submit"
            class="flex w-full items-center justify-center gap-2 rounded-lg bg-alt px-6 py-3 font-medium text-[#1B2A49] transition hover:opacity-90"
          >
            <i class="bi bi-arrow-repeat hidden animate-spin" id="spinnerBuild"></i>
            <span>Subir</span>
          </button>
        </form>
      </div>
    </div>
  </div>
{% endblock %}

{% block scripts %}
  <script src="{{ asset('vendor/simplemde/simplemde.min.js') }}"></script>
  <script src="{{ asset('js/components/gradientChip.js') }}"></script>
  <script src="{{ asset('js/components/fileUpload.js') }}"></script>
  <script src="{{ asset('js/forms/dev/getStoreID.js') }}"></script>
  <script src="{{ asset('js/forms/validator.js') }}"></script>
  <script src="{{ asset('js/orion-panel/dev/store.js') }}"></script>
{% endblock %}
