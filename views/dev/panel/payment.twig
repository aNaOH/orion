{% extends 'layouts/admin.twig' %}

{% set is_dev_panel = true %}
{% set title = 'Gestión de Pagos | Orion Dev Panel' %}
{% set panel_title = title %}

{% block content %}
<div class="max-w-6xl mx-auto animate__animated animate__fadeIn">
    <div class="mb-8 flex items-center justify-between">
        <h1 class="text-2xl font-bold text-alt">Gestión de Pagos</h1>
        <a href="/dev/panel" class="text-gray-400 hover:text-alt transition">Volver al Inicio</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-branddark-700/50 backdrop-blur-md border border-branddark-500 rounded-2xl p-6 shadow-xl">
            <p class="text-gray-400 text-sm mb-1">Saldo Pendiente</p>
            <h3 class="text-3xl font-bold text-alt">0,00 €</h3>
            <p class="text-xs text-gray-500 mt-2">Próximo pago: 1 de Junio</p>
        </div>
        <div class="bg-branddark-700/50 backdrop-blur-md border border-branddark-500 rounded-2xl p-6 shadow-xl">
            <p class="text-gray-400 text-sm mb-1">Ventas del Mes</p>
            <h3 class="text-3xl font-bold text-white">0</h3>
            <p class="text-xs text-green-400 mt-2"><i class="bi bi-arrow-up"></i> 0% vs mes anterior</p>
        </div>
        <div class="bg-branddark-700/50 backdrop-blur-md border border-branddark-500 rounded-2xl p-6 shadow-xl">
            <p class="text-gray-400 text-sm mb-1">Ingresos Totales</p>
            <h3 class="text-3xl font-bold text-white">0,00 €</h3>
            <p class="text-xs text-gray-500 mt-2">Desde la creación de la cuenta</p>
        </div>
    </div>

    <div class="bg-branddark-700/50 backdrop-blur-md border border-branddark-500 rounded-2xl overflow-hidden shadow-xl">
        <div class="px-6 py-4 border-b border-branddark-500 bg-branddark-600/50 flex items-center justify-between">
            <h3 class="font-semibold text-white">Historial de Transacciones</h3>
            <button class="text-xs bg-branddark-500 hover:bg-branddark-400 text-white px-3 py-1 rounded transition">Descargar CSV</button>
        </div>
        <div class="p-12 text-center">
            <i class="bi bi-receipt text-5xl text-branddark-500 mb-4 block"></i>
            <p class="text-gray-400">No hay transacciones registradas aún.</p>
        </div>
    </div>
</div>
{% endblock %}
