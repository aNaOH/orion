{% extends 'layouts/community_dashboard.twig' %}

{% block title %}Comunidad de {{ game.title }} - Orion{% endblock %}

{% block community_content %}
    <div class="space-y-8">
        <div class="flex items-center justify-between">
            <h2 class="text-2xl font-bold text-white">Actividad reciente</h2>
            <div class="flex items-center gap-2">
                <span class="text-xs text-gray-500 font-medium">Ordenar por:</span>
                <select class="bg-transparent text-gray-400 text-xs font-bold border-none focus:ring-0 cursor-pointer hover:text-white">
                    <option value="new">Novedades</option>
                    <option value="popular">Popular</option>
                </select>
            </div>
        </div>

        <div class="space-y-6">
            {% for post in recentActivity %}
                {% set type_str = 'posts' %}
                {% if post.type.value == 1 %}{% set type_str = 'gallery' %}
                {% elseif post.type.value == 2 %}{% set type_str = 'guides' %}
                {% elseif post.type.value == 3 %}{% set type_str = 'news' %}{% endif %}

                {% if post.type.value == 1 %}
                    {% include 'partials/gallery_card.twig' with {'post': post, 'user_vote_value': post.user_vote_value|default(0)} %}
                {% else %}
                    {% include 'partials/post_card.twig' with {'post': post, 'post_type': type_str} %}
                {% endif %}
            {% else %}
                <div class="py-20 text-center bg-branddark/20 rounded-3xl border border-dashed border-white/10">
                    <i class="bi bi-chat-dots text-4xl text-gray-600 mb-4 block"></i>
                    <p class="text-gray-500">Aún no hay actividad en esta comunidad.<br>¡Sé el primero en publicar algo!</p>
                    <a href="/login" class="inline-block mt-6 text-alt font-bold hover:underline">Crear un post</a>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}

{% block scripts %}
    <script src="{{ asset('js/addDatesCommunity.js') }}"></script>
    <script src="{{ asset('js/components/galleryvote.js') }}"></script>
    <script src="{{ asset('js/galleryIndex.js') }}"></script>
{% endblock %}
