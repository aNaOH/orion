{% extends 'layouts/base.twig' %}

{% block title %}{{ title }} - Orion{% endblock %}

{% block content %}
<!-- Hero Section -->
<section id="hero" class="bg-brand-500 text-white py-20 -mt-8 mb-10">
    <div class="container mx-auto text-center px-4">
        <h2 class="text-4xl md:text-5xl font-bold transition-all">{{ title }}</h2>
        {% if session_user %}
            <div class="mt-6">
                <a href="/communities/{{ game.id }}/{{ post_type }}/create" class="px-6 py-3 bg-alt hover:bg-alt-400 text-white font-semibold rounded-lg shadow-md transition-all">
                    Nuevo {% if post_type == 'gallery' %}post{% elseif post_type == 'guides' %}guía{% else %}post{% endif %}
                </a>
            </div>
        {% endif %}
    </div>
</section>

<!-- Content Section -->
<section id="content" class="py-10">
    <div class="container mx-auto px-4">
        <div class="space-y-6 max-w-4xl mx-auto">
            {% if posts is empty %}
                <div class="text-center py-10 bg-branddark-600 rounded-xl border border-gray-700/50">
                    <p class="text-gray-400">No hay contenido aún en esta categoría.</p>
                </div>
            {% else %}
                {% for post in posts %}
                    {% if post.is_public %}
                        {% if post_type == 'gallery' %}
                            {# The 'gallery_card' needs the user vote if logged in #}
                            {% include 'partials/gallery_card.twig' with {'post': post, 'user_vote_value': post.user_vote_value|default(0)} %}
                        {% else %}
                            <!-- Standard Post Item -->
                            <a href="/communities/{{ game.id }}/{{ post_type }}/{{ post.id }}" class="block bg-branddark shadow-lg rounded-lg p-6 hover:bg-branddark-600 transition-all border border-gray-700/50">
                                <div class="flex justify-between items-center whitespace-nowrap overflow-hidden">
                                    <div class="overflow-hidden">
                                        <h6 class="text-lg font-semibold text-gray-200 mb-1 truncate">{{ post.title }}</h6>
                                        <p class="text-sm text-gray-400">de <span class="text-alt font-medium">{{ post.getAuthor().username }}</span></p>
                                    </div>
                                    <small class="text-gray-500 text-sm ml-4" data-createdate="{{ post.created_at|date('Y-m-d H:i:s') }}">
                                        {{ post.created_at|date('d/m/Y') }}
                                    </small>
                                </div>
                            </a>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            {% endif %}
        </div>
    </div>
</section>
{% endblock %}

{% block scripts %}
    {# Generic community JS helpers #}
    <script src="{{ asset('js/addDatesCommunity.js') }}"></script>
    {% if post_type == 'gallery' %}
        <script src="{{ asset('js/components/galleryvote.js') }}"></script>
        <script src="{{ asset('js/galleryIndex.js') }}"></script>
    {% endif %}
{% endblock %}
