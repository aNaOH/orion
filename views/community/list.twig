{% extends 'layouts/community_dashboard.twig' %}

{% block title %}{{ title }} - Orion{% endblock %}

{% block community_content %}
    <div class="space-y-8">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-3xl font-black text-white tracking-tight">{{ title }}</h2>
                <p class="text-gray-400 mt-1">Explora las últimas aportaciones de la comunidad</p>
            </div>
            
            {% set is_dev = game.getDeveloper().owner_id == session_user.id %}
            {% if session_user %}
                {% if post_type == 'news' and is_dev %}
                    <a href="/dev/panel/games/{{ game.id }}/community/news" class="flex items-center gap-2 px-6 py-3 bg-branddark-600 hover:bg-branddark-500 text-white font-bold rounded-xl border border-white/10 shadow-lg transition-all hover:scale-105">
                        <i class="bi bi-gear-fill text-alt"></i>
                        Gestionar noticias
                    </a>
                {% elseif post_type != 'news' or is_dev %}
                    <a href="/communities/{{ game.id }}/{{ post_type }}/create" class="flex items-center gap-2 px-6 py-3 bg-alt hover:bg-alt-600 text-white font-bold rounded-xl shadow-lg transition-all hover:scale-105">
                        <i class="bi bi-plus-lg"></i>
                        Nuevo {% if post_type == 'gallery' %}post{% elseif post_type == 'guides' %}guía{% elseif post_type == 'news' %}noticia{% else %}post{% endif %}
                    </a>
                {% endif %}
            {% endif %}
        </div>

        <div class="space-y-6">
            {% if posts is empty %}
                <div class="py-20 text-center bg-branddark/20 rounded-3xl border border-dashed border-white/10">
                    <i class="bi bi-chat-dots text-4xl text-gray-600 mb-4 block"></i>
                    <p class="text-gray-500">No hay contenido aún en esta categoría.<br>¡Sé el primero en publicar algo!</p>
                </div>
            {% else %}
                {% for post in posts %}
                    {% if post.is_public %}
                        {% if post_type == 'gallery' %}
                            {% include 'partials/gallery_card.twig' with {'post': post, 'user_vote_value': post.user_vote_value|default(0)} %}
                        {% else %}
                            {% include 'partials/post_card.twig' with {'post': post, 'post_type': post_type} %}
                        {% endif %}
                    {% endif %}
                {% endfor %}
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block scripts %}
    <script src="{{ asset('js/addDatesCommunity.js') }}"></script>
    {% if post_type == 'gallery' %}
        <script src="{{ asset('js/components/galleryvote.js') }}"></script>
        <script src="{{ asset('js/galleryIndex.js') }}"></script>
    {% endif %}
{% endblock %}
