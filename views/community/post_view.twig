{% extends 'layouts/base.twig' %}

{% block title %}Post '{{ post.title }}' - {{ game.title }} - Orion{% endblock %}

{% block content %}
<!-- Content Section -->
<div class="max-w-4xl mx-auto py-10 px-4">
    
    {% if post_type == 'gallery' %}
        {# Gallery items use the same card component as the list for consistency #}
        <div class="mb-10">
            {% include 'partials/gallery_card.twig' with {'post': post, 'user_vote_value': user_vote_value|default(0)} %}
        </div>
    {% else %}
        <!-- Standard Post Header -->
        <header class="mb-10 text-center">
            <h1 class="text-4xl md:text-5xl font-bold text-gray-100 mb-4">{{ post.title }}</h1>
            <p class="text-lg text-gray-400">
                Escrito por 
                <a href="/profile/{{ post.getAuthor().id }}" class="font-semibold text-alt hover:underline">
                    {{ post.getAuthor().username }}
                </a>
                {#- Rendered as inline to avoid space before date #}
                <span class="mx-2">•</span>
                <span data-createdate="{{ post.created_at|date('Y-m-d H:i:s') }}">{{ post.created_at|date('d/m/Y') }}</span>
            </p>
        </header>

        <!-- Post Body -->
        <article class="prose prose-invert prose-lg max-w-none bg-branddark p-8 rounded-xl border border-gray-700/50 shadow-lg mb-10">
            {{ post.body|markdown }}
        </article>
    {% endif %}

    <!-- Comments Section -->
    <section id="comments" class="bg-branddark rounded-xl border border-gray-700/50 shadow-lg overflow-hidden">
        <div class="p-6 border-b border-gray-700/50">
            <h2 class="text-2xl font-bold text-gray-100 flex items-center">
                <i class="bi bi-chat-left-text-fill mr-3 text-alt"></i>
                Comentarios
            </h2>
        </div>

        <div class="p-6 space-y-6">
            {% if session_user %}
                <!-- Comment Form -->
                <form id="commentForm" method="post" action="/api/communities/comment/{{ post.id }}" class="mb-10">
                    {{ token_input('USERACTION') }}
                    <div class="bg-branddark-600 flex flex-col md:flex-row p-4 gap-5 rounded-xl border border-alt-500/30">
                        <div class="w-16 h-16 rounded-full overflow-hidden border-4 border-alt-500 flex-shrink-0 hidden md:block">
                            <img src="{{ profile_pic(user) }}" alt="Tu foto de perfil" class="w-full h-full object-cover">
                        </div>
                        <div class="flex flex-col gap-3 w-full">
                            <p class="font-semibold text-gray-200">Comentando como <span class="text-alt">{{ session_user.username }}</span></p>
                            <textarea name="comment" id="comment" rows="3" required placeholder="Escribe aquí tu comentario" 
                                class="p-3 rounded-xl text-gray-200 w-full bg-branddark border border-gray-700 focus:border-alt focus:ring-1 focus:ring-alt outline-none transition-all resize-none"></textarea>
                            <div class="flex justify-end">
                                <button class="px-6 py-2 bg-alt hover:bg-alt-400 text-white font-bold rounded-lg shadow-lg transition-all" id="submitButton" type="submit">
                                    Comentar
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            {% else %}
                <div class="mb-10 p-4 bg-branddark-600 rounded-xl border border-dashed border-gray-600 text-center text-gray-400">
                    <p>Debes <a href="/login" class="text-alt font-bold hover:underline">iniciar sesión</a> para comentar.</p>
                </div>
            {% endif %}

            <!-- Comments List -->
            <div class="space-y-4">
                {% set comments = post.getComments() %}
                {% if comments is empty %}
                    <p class="text-center text-gray-500 py-4">Aún no hay comentarios. ¡Sé el primero en comentar!</p>
                {% else %}
                    {% for comment in comments %}
                        {% include 'partials/comment.twig' with {'comment': comment} %}
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </section>
</div>
{% endblock %}

{% block scripts %}
    <script src="{{ asset('js/addDatesCommunity.js') }}"></script>
    {% if post_type == 'gallery' %}
        <script src="{{ asset('js/components/galleryvote.js') }}"></script>
        <script src="{{ asset('js/galleryPost.js') }}"></script>
    {% endif %}
{% endblock %}
