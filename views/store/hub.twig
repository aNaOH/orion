{% extends "layouts/base.twig" %}

{% block title %}Tienda | Orion{% endblock %}

{% block content %}
    <script src="{{ asset('js/components/gradientChip.js') }}"></script>

    <!-- Hero Section -->
    <section id="hero" class="bg-brand-500 text-white py-20 -mt-8 mb-8 shadow-inner">
        <div class="container mx-auto text-center px-6">
            <h2 class="text-4xl md:text-5xl font-bold animate__animated animate__fadeInDown">Tienda</h2>
            <p class="text-lg md:text-xl mt-4">¡Descubre tu próximo videojuego!</p>
            
            <form id="searchForm" action="/store/games" method="GET" class="flex items-center space-x-2 p-2 mt-8 rounded-full bg-branddark bg-opacity-75 shadow-md w-full max-w-2xl mx-auto border border-white/10 focus-within:border-alt transition-all">
                <div class="relative flex-grow">
                    <input
                        type="text"
                        name="search"
                        id="search"
                        placeholder="¡Mira si lo tenemos aquí!"
                        class="w-full bg-transparent text-gray-200 placeholder-text-gray-200/75 px-6 py-3 rounded-full border-none focus:outline-none"
                    >
                    <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-white/50">
                        <i class="bi bi-search text-xl"></i>
                    </div>
                </div>
            </form>
        </div>
    </section>

    <div class="container mx-auto px-6">
        <!-- Mobile Filter Button -->
        <div class="lg:hidden mb-6">
            <button id="openMobileFilters" class="w-full flex items-center justify-center gap-3 bg-branddark/80 hover:bg-branddark text-white font-bold py-4 px-6 rounded-2xl border border-white/10 shadow-lg transition-all active:scale-95">
                <i class="bi bi-funnel text-alt"></i>
                Filtrar y Buscar
                {% if filteredGender != 'all' or filteredFeatures|length > 0 or searchQuery != '' %}
                    <span class="w-2 h-2 bg-alt rounded-full"></span>
                {% endif %}
            </button>
        </div>

        <div class="flex flex-col lg:flex-row gap-10 relative">
            <!-- Sidebar Filters (Drawer on Mobile) -->
            <aside id="sidebarFilters" class="fixed inset-0 z-50 lg:relative lg:inset-auto lg:z-0 lg:w-64 flex-shrink-0 invisible lg:visible opacity-0 lg:opacity-100 transition-all duration-300">
                <!-- Mobile Overlay Backdrop -->
                <div id="mobileFiltersBackdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm lg:hidden"></div>
                
                <form id="filterForm" action="/store/games" method="GET" class="relative w-4/5 max-w-sm h-full lg:h-auto lg:w-full bg-branddark lg:bg-branddark/50 p-8 lg:p-6 lg:rounded-2xl border-r lg:border border-white/10 lg:border-white/5 shadow-2xl lg:shadow-xl overflow-y-auto lg:overflow-visible transition-transform -translate-x-full lg:translate-x-0">
                    <div class="flex items-center justify-between lg:hidden mb-8">
                        <h3 class="text-xl font-bold text-white">Filtros</h3>
                        <button type="button" id="closeMobileFilters" class="text-2xl text-gray-400 hover:text-white">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>

                    <input type="hidden" name="search" value="{{ searchQuery }}">
                    
                    <div class="space-y-8">
                        <div>
                            <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                                <i class="bi bi-controller text-alt"></i> Género
                            </h3>
                            <select name="genre" class="w-full rounded-xl bg-branddark text-gray-200 px-4 py-2.5 border border-white/10 focus:border-alt focus:ring-0 transition-all cursor-pointer">
                                <option value="all">Todos los géneros</option>
                                {% for genre in genres %}
                                    <option value="{{ genre.id }}" {{ genre.id == filteredGender ? 'selected' : '' }}>{{ genre.name }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div>
                            <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                                <i class="bi bi-stars text-alt"></i> Características
                            </h3>
                            <div class="space-y-3">
                                {% for feature in features %}
                                    <label class="flex items-center group cursor-pointer w-full gap-3">
                                        <div class="relative flex items-center justify-center w-5 h-5 flex-shrink-0">
                                            <input type="checkbox" name="features[]" value="{{ feature.id }}" class="peer hidden" {{ feature.id in filteredFeatures ? 'checked' : '' }}>
                                            <div class="absolute inset-0 border-2 border-white/20 rounded peer-checked:bg-alt peer-checked:border-alt transition-all"></div>
                                            <i class="bi bi-check relative text-white opacity-0 peer-checked:opacity-100 transition-opacity text-xl leading-none"></i>
                                        </div>
                                        <gradient-chip
                                            base-color="{{ feature.tint }}"
                                            size="12"
                                            icon-path="https://cdn.orion.moonnastd.com/game/feature/{{ feature.icon }}"
                                            text="{{ feature.name }}"
                                            border-radius="8"
                                            full-width="true"
                                            class="flex-1 group-hover:scale-[1.01] transition-transform min-w-0"
                                        ></gradient-chip>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                    <button type="submit" class="w-full bg-alt hover:bg-alt-600 text-white font-bold py-3 px-6 rounded-xl mt-10 shadow-lg shadow-alt/20 transition-all active:scale-95">
                        Filtrar
                    </button>
                    {% if filteredGender != 'all' or filteredFeatures|length > 0 or searchQuery != '' %}
                        <a href="/store" class="block w-full text-center text-gray-400 hover:text-white text-sm mt-4 transition-colors">
                            Limpiar filtros
                        </a>
                    {% endif %}
                </form>
            </aside>

            <!-- Main Content -->
            <main class="flex-grow space-y-16 pb-20">
                {% if recommended is defined and recommended|length > 0 %}
                    <section>
                        <div class="flex items-center gap-4 mb-8">
                            <h2 class="text-3xl font-bold text-white">Pensamos que podría interesarte</h2>
                            <div class="h-1 flex-grow bg-gradient-to-r from-alt/50 to-transparent rounded-full"></div>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-8 justify-items-center">
                            {% for game in recommended %}
                                {% if game.is_public %}
                                    {% include 'partials/game_store_card.twig' with {'game': game} %}
                                {% endif %}
                            {% endfor %}
                        </div>
                    </section>
                {% endif %}

                <section>
                    <div class="flex items-center gap-4 mb-8">
                        <h2 class="text-3xl font-bold text-white">Algunos juegos de nuestro catálogo</h2>
                        <div class="h-1 flex-grow bg-gradient-to-r from-alt/30 to-transparent rounded-full"></div>
                    </div>
                    
                    {% if randomGames is defined and randomGames|length > 0 %}
                        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-8 justify-items-center">
                            {% for game in randomGames %}
                                {% if game.is_public %}
                                    {% include 'partials/game_store_card.twig' with {'game': game} %}
                                {% endif %}
                            {% endfor %}
                        </div>
                        <div class="mt-16 text-center">
                            <a href="/store/games" class="inline-flex items-center gap-2 px-10 py-4 bg-white/5 hover:bg-white/10 text-white font-bold rounded-2xl border border-white/10 hover:border-alt transition-all group">
                                Ver catálogo completo
                                <i class="bi bi-arrow-right group-hover:translate-x-1 transition-transform"></i>
                            </a>
                        </div>
                    {% else %}
                        <div class="bg-branddark/30 rounded-3xl p-20 text-center border border-dashed border-white/10">
                            <i class="bi bi-controller text-6xl text-white/10 mb-4 block"></i>
                            <h3 class="text-2xl font-bold text-white/50">No hay juegos disponibles...</h3>
                            <p class="text-gray-400 mt-2">¡Vuelve pronto para descubrir nuevos títulos increíbles!</p>
                        </div>
                    {% endif %}
                </section>
            </main>
        </div>
    </div>
{% endblock %}

{% block scripts %}
    <script src="{{ asset('js/storeFiltering.js') }}"></script>
{% endblock %}
