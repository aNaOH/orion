<div class="relative rounded-lg overflow-hidden group w-60 h-90 shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105">
    <a class="aspect-[2/3]" href="/store/{{ game.id }}">
      <img
        src="https://cdn.orion.moonnastd.com/game/cover/{{ game.id }}"
        class="w-full h-full object-cover"
        alt="{{ game.title }} cover"
      />
      <!-- Degradado y título -->
      <div class="absolute inset-0 bg-gradient-to-t from-black via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
        <h3 class="text-white text-base font-semibold">{{ game.title }}</h3>
      </div>
    </a>
</div>
