{# Comment Component #}
<div class="flex gap-4 group">
    <a href="/profile/{{ comment.getAuthor().id }}" class="flex-shrink-0">
        <img src="{{ profile_pic(comment.getAuthor()) }}" alt="{{ comment.getAuthor().username }}" class="w-12 h-12 rounded-full border-2 border-white/5 group-hover:border-alt/50 transition-colors">
    </a>
    <div class="flex-grow space-y-1">
        <div class="flex items-center gap-2">
            <a href="/profile/{{ comment.getAuthor().id }}" class="text-sm font-bold text-white hover:text-alt transition-colors">
                {{ user_handle(comment.getAuthor()) }}
            </a>
            <span class="text-[10px] text-gray-500">•</span>
            <span class="text-xs text-gray-500">
                {{ comment.created_at|time_ago }}
            </span>
        </div>
        <div class="bg-white/5 p-4 rounded-2xl rounded-tl-none border border-white/5 group-hover:border-white/10 transition-colors">
            <p class="text-gray-300 text-sm leading-relaxed">{{ comment.body }}</p>
        </div>
    </div>
</div>
