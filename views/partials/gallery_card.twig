{# Gallery Card Component #}
<div data-gameid="{{ game.id }}" class="max-w-xl mx-auto bg-branddark/60 rounded-3xl overflow-hidden mb-8 border border-white/5 shadow-2xl group">
    <div class="p-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
            {% set author = post.getAuthor() %}
            <a href="/profile/{{ author.id }}" class="flex-shrink-0">
                <img src="{{ profile_pic(author) }}" class="w-10 h-10 rounded-full border-2 border-white/5" alt="{{ author.username }}">
            </a>
            <div>
                <h3 class="text-white font-bold group-hover:text-alt transition-colors">{{ post.title }}</h3>
                <p class="text-[10px] text-gray-500 uppercase tracking-wider">
                    {{ author.username }} • {{ post.created_at|time_ago }}
                </p>
            </div>
        </div>
        
        <div class="flex flex-row gap-2 relative">
            <div data-galleryslot="shareBtn" data-postid="{{ post.id }}" class="w-8 h-8 rounded-xl bg-white/5 hover:bg-alt text-gray-400 hover:text-white cursor-pointer flex items-center justify-center transition-all">
                <i class="bi bi-share"></i>
            </div>
            <div data-galleryslot="shareLink" class="hidden absolute right-6 top-16 z-50 p-3 bg-branddark border border-white/10 rounded-2xl shadow-2xl">
                <input data-galleryslot="linkInput" type="text" class="w-64 p-2 text-xs border-none rounded-xl bg-white/5 text-gray-200" readonly>
            </div>
        </div>
    </div>

    {# Media slot for JS injection #}
    <div data-galleryslot="media" data-uuid="{{ post.getPostInfo().media }}" class="bg-black/20 aspect-video flex items-center justify-center">
        <i class="bi bi-image text-gray-700 text-4xl animate-pulse"></i>
    </div>

    <!-- Vote and Interaction -->
    <div class="p-6 bg-branddark-600/30 flex items-center justify-between">
        <div class="flex items-center gap-4">
            <div class="flex items-center gap-2 px-3 py-1.5 bg-white/5 rounded-full">
                <i class="bi bi-star-fill text-alt text-xs"></i>
                <span data-galleryslot="value" class="text-white font-bold text-sm">{{ post.getPostInfo().getValue() }}</span>
            </div>
            {% set type_slug = 'posts' %}
            {% if post.type.value == 'gallery' %}{% set type_slug = 'gallery' %}
            {% elseif post.type.value == 'guide' %}{% set type_slug = 'guides' %}
            {% elseif post.type.value == 'news' %}{% set type_slug = 'news' %}{% endif %}
            
            <a href="/communities/{{ game.id }}/{{ type_slug }}/{{ post.id }}#comments" class="text-gray-500 hover:text-alt transition-colors flex items-center gap-2">
                <i class="bi bi-chat-text"></i>
                <span class="text-xs">{{ post.getComments()|length }}</span>
            </a>
        </div>

        <div class="flex items-center gap-3">
            {% if session_user %}
                <gallery-vote value="{{ user_vote_value|default(0) }}"></gallery-vote>
            {% else %}
                <a href="/login" class="px-4 py-2 bg-alt/10 hover:bg-alt/20 text-alt text-xs font-bold rounded-xl transition-all">
                    Iniciar sesión para votar
                </a>
            {% endif %}
        </div>
    </div>
</div>
