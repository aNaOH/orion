<div class="relative rounded-2xl overflow-hidden group w-64 h-96 shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-[1.03] mx-auto lg:mx-0 border border-white/5 hover:border-alt/30">
    <a class="w-full h-full block" href="/communities/{{ game.id }}">
        <img
            src="https://cdn.orion.moonnastd.com/game/cover/{{ game.id }}"
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
            alt="{{ game.title }} cover"
        />
        <!-- Overlay and Title -->
        <div class="absolute inset-0 bg-gradient-to-t from-branddark via-branddark/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-end p-6">
            <div>
                <h3 class="text-white text-xl font-bold translate-y-4 group-hover:translate-y-0 transition-transform duration-300">{{ game.title }}</h3>
                <p class="text-alt text-sm font-medium mt-1 translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Ver comunidad</p>
            </div>
        </div>
    </a>
</div>
