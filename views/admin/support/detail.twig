{% extends 'layouts/admin.twig' %}

{% block title %}Ticket #{{ ticket.id }} - Orion Admin{% endblock %}

{% block content %}
<section class="py-10">
    <div class="container mx-auto px-4">
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <a href="/admin/tickets" class="text-gray-500 hover:text-white transition text-sm flex items-center mb-2">
                    <i class="bi bi-arrow-left mr-1"></i> Volver al listado
                </a>
                <h1 class="text-3xl font-bold text-gray-100 flex items-center">
                    Ticket #{{ ticket.id }} 
                    <span class="ml-4 uppercase text-sm bg-blue-500/20 text-blue-400 px-3 py-1 rounded-full border border-blue-500/30">
                        {{ ticket.type }}
                    </span>
                </h1>
            </div>
            <div>
                {% if ticket.status == 0 %}
                    <span class="px-4 py-2 bg-yellow-400/10 text-yellow-400 border border-yellow-400/20 rounded-lg text-sm font-bold flex items-center">
                        <i class="bi bi-clock-fill mr-2"></i> PENDIENTE
                    </span>
                {% elseif ticket.status == 1 %}
                    <span class="px-4 py-2 bg-green-400/10 text-green-400 border border-green-400/20 rounded-lg text-sm font-bold flex items-center">
                        <i class="bi bi-check-circle-fill mr-2"></i> ACEPTADO
                    </span>
                {% else %}
                    <span class="px-4 py-2 bg-red-400/10 text-red-400 border border-red-400/20 rounded-lg text-sm font-bold flex items-center">
                        <i class="bi bi-x-circle-fill mr-2"></i> RECHAZADO
                    </span>
                {% endif %}
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Side: Details -->
            <div class="lg:col-span-2 space-y-8">
                <!-- Reporter Info -->
                <div class="bg-branddark rounded-xl p-6 border border-white/5">
                    <h2 class="text-lg font-bold text-gray-200 mb-4 flex items-center">
                        <i class="bi bi-person-fill mr-2 text-alt"></i> Información del Reportero
                    </h2>
                    <div class="flex items-center space-x-4">
                        <img src="{{ profile_pic(reporter) }}" class="w-12 h-12 rounded-full object-cover">
                        <div>
                            <p class="text-white font-bold">{{ reporter.username }}</p>
                            <p class="text-gray-500 text-sm">{{ reporter.email }}</p>
                        </div>
                    </div>
                </div>

                <!-- Report Content -->
                {% if ticket.type == "report_user" %}
                    <div class="bg-branddark rounded-xl p-6 border border-white/5">
                        <h2 class="text-lg font-bold text-gray-200 mb-4 flex items-center">
                            <i class="bi bi-exclamation-triangle-fill mr-2 text-red-500"></i> Contenido del Reporte
                        </h2>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-500 uppercase">Motivo</label>
                                <p class="text-gray-200">{{ report.reason }}</p>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-500 uppercase">Descripción</label>
                                <p class="text-gray-300 whitespace-pre-wrap mt-1 bg-brand-900 p-4 rounded-lg border border-white/5">{{ report.description }}</p>
                            </div>
                        </div>
                    </div>

                    <!-- Snapshot -->
                    <div class="bg-branddark rounded-xl p-6 border border-white/5">
                        <h2 class="text-lg font-bold text-gray-200 mb-4 flex items-center">
                            <i class="bi bi-camera-fill mr-2 text-blue-400"></i> Snapshot en el momento del reporte
                        </h2>
                        <div class="bg-brand-900 rounded-xl p-6 border border-white/10">
                            <div class="flex items-center space-x-6">
                                <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-alt/30">
                                    <img src="{{ cdn_url('snapshot', report.snapshot.profile_pic) }}" alt="Snapshot Avatar" class="w-full h-full object-cover">
                                </div>
                                <div>
                                    <h3 class="text-2xl font-bold text-white">{{ report.snapshot.username }}</h3>
                                    <p class="text-gray-400 italic text-lg">{{ report.snapshot.motd ?: "Sin mensaje personalizado." }}</p>
                                </div>
                            </div>
                        </div>
                        <p class="mt-4 text-xs text-gray-500 italic">
                            <i class="bi bi-info-circle mr-1"></i> Estos datos quedaron congelados al momento de crear el reporte.
                        </p>
                    </div>
                {% endif %}
            </div>

            <!-- Right Side: Action Panel -->
            <div class="space-y-8">
                <div class="bg-branddark rounded-xl p-6 border border-white/5 sticky top-8">
                    <h2 class="text-lg font-bold text-gray-200 mb-4 flex items-center">
                        <i class="bi bi-shield-check mr-2 text-alt"></i> Resolución
                    </h2>
                    
                    {% if ticket.status == 0 %}
                        <form id="resolve-form" class="space-y-4">
                            {{ token_input('COMMON') | raw }}
                            <input type="hidden" name="id" value="{{ ticket.id }}">
                            
                            <div>
                                <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Acción</label>
                                <div class="grid grid-cols-2 gap-2">
                                    <label class="cursor-pointer">
                                        <input type="radio" name="status" value="1" class="hidden peer" checked>
                                        <div class="text-center p-3 rounded-lg border border-white/10 bg-brand-900 text-gray-400 peer-checked:bg-green-600/20 peer-checked:border-green-600 peer-checked:text-green-500 transition">
                                            Aceptar
                                        </div>
                                    </label>
                                    <label class="cursor-pointer">
                                        <input type="radio" name="status" value="2" class="hidden peer">
                                        <div class="text-center p-3 rounded-lg border border-white/10 bg-brand-900 text-gray-400 peer-checked:bg-red-600/20 peer-checked:border-red-600 peer-checked:text-red-500 transition">
                                            Rechazar
                                        </div>
                                    </label>
                                </div>
                            </div>

                            <div>
                                <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Comentario para el usuario</label>
                                <textarea name="admin_comment" rows="4" class="w-full bg-brand-900 border border-white/10 rounded-lg px-4 py-3 text-white text-sm focus:outline-none focus:border-alt-500 transition shadow-inner" placeholder="Explica el motivo de la resolución..."></textarea>
                            </div>

                            <button type="submit" id="submit-btn" class="w-full py-3 bg-alt hover:bg-alt-400 text-white font-bold rounded-lg transition shadow-lg shadow-alt/20">
                                Resolver Ticket
                            </button>
                        </form>
                    {% else %}
                        <div class="space-y-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-500 uppercase">Comentario de Resolución</label>
                                <p class="text-gray-300 mt-1 italic">"{{ ticket.admin_comment ?: "Sin comentarios adicionales." }}"</p>
                            </div>
                            <div class="pt-4 text-xs text-gray-500">
                                Resuelto el {{ ticket.updated_at|date("d/m/Y H:i") }}
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block scripts %}
<script>
    $('#resolve-form').on('submit', function(e) {
        e.preventDefault();
        
        const btn = $('#submit-btn');
        const status = $('input[name="status"]:checked').val();
        const comment = $('textarea[name="admin_comment"]').val();
        
        if (status == 2 && comment.length < 5) {
            alert('Por favor, indica un motivo para el rechazo.');
            return;
        }

        if (!confirm('¿Estás seguro de resolver este ticket con esta acción? Se enviará un correo al usuario.')) return;

        btn.prop('disabled', true).text('Procesando...');

        $.ajax({
            url: '/admin/tickets/api/update',
            method: 'POST',
            data: $(this).serialize(),
            success: function(response) {
                location.reload();
            },
            error: function(xhr) {
                alert('Error al actualizar ticket');
                btn.prop('disabled', false).text('Resolver Ticket');
            }
        });
    });
</script>
{% endblock %}
