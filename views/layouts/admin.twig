{% include 'layouts/panel/header.twig' %}

{% if is_dev_panel %}
    {% include 'layouts/panel/dev_sidebar.twig' %}
{% else %}
    {% include 'layouts/panel/admin_sidebar.twig' %}
{% endif %}

<!-- CONTENIDO -->
<div id="main-content" class="flex-1 flex flex-col bg-branddark-800 overflow-hidden">
  <!-- HEADER -->
  <header
    class="flex items-center justify-between px-6 py-4 border-b border-branddark-600 bg-branddark-700 shadow-sm flex-shrink-0">
    <div class="flex items-center gap-3">
      <button id="sidebarToggle" class="text-gray-400 hover:text-alt-400 transition md:block hidden">
        <i class="bi bi-list text-2xl"></i>
      </button>
      <h2 class="text-xl font-lg">{{ panel_title|default(is_dev_panel ? 'Panel de Desarrollador' : 'Panel de Administración') }}</h2>
    </div>
    <div class="flex items-center gap-5">
      <button class="hover:text-alt-400 transition">
        <i class="bi bi-bell text-xl"></i>
      </button>
    </div>
  </header>

  <!-- MAIN -->
  <main class="flex-1 p-8 overflow-y-auto">
    {% block content %}{% endblock %}
  </main>
</div>

{% include 'layouts/panel/footer.twig' %}
{% block scripts %}{% endblock %}
