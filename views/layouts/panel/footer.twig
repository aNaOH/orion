    </div>

    <!-- TOOLTIP -->
    <div id="tooltip" class="fixed bg-gray-800 text-gray-100 text-xs px-2 py-1 rounded-md shadow-lg opacity-0 pointer-events-none transition-all duration-200 z-50"></div>

    <script>
        const sidebar = $("#sidebar");
        const body = $("body");
        const tooltip = $("#tooltip");

        // Toggle sidebar
        $("#sidebarToggle").on("click", function () {
            body.toggleClass("sidebar-collapsed");
        });

        // Toggle móvil
        $("#sidebarToggleMobile").on("click", function () {
            sidebar.removeClass("mobile-active");
        });

        $(document).on("click", function (e) {
            if (sidebar.hasClass("mobile-active") && !$(e.target).closest("#sidebar, #sidebarToggle").length) {
                sidebar.removeClass("mobile-active");
            }
        });

        // Tooltip
        $(".menu-item").hover(function (e) {
            if ($("body").hasClass("sidebar-collapsed")) {
                const text = $(this).data("tooltip");
                if (text) {
                    tooltip.text(text);
                    const rect = this.getBoundingClientRect();
                    tooltip.css({
                        top: rect.top + rect.height / 2 - 10,
                        left: rect.right + 10,
                        opacity: 1
                    });
                }
            }
        }, function () {
            tooltip.css("opacity", 0);
        });

        // Orion Global Helper
        window.Orion = {
            showToast: function(type, message) {
                const toastContainer = document.getElementById('toast-container') || this.createToastContainer();
                const toast = document.createElement('div');
                
                const bgColor = type === 'success' ? 'bg-green-500/20' : 'bg-red-500/20';
                const borderColor = type === 'success' ? 'border-green-500/50' : 'border-red-500/50';
                const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';
                const iconColor = type === 'success' ? 'text-green-400' : 'text-red-400';

                toast.className = `flex items-center gap-3 px-6 py-4 rounded-xl border ${bgColor} ${borderColor} backdrop-blur-md shadow-2xl animate__animated animate__fadeInRight mb-3 min-w-[300px]`;
                toast.innerHTML = `
                    <i class="bi ${icon} ${iconColor} text-xl"></i>
                    <p class="text-white font-medium">${message}</p>
                `;

                toastContainer.appendChild(toast);

                setTimeout(() => {
                    toast.classList.replace('animate__fadeInRight', 'animate__fadeOutRight');
                    setTimeout(() => toast.remove(), 500);
                }, 4000);
            },
            createToastContainer: function() {
                const container = document.createElement('div');
                container.id = 'toast-container';
                container.className = 'fixed bottom-8 right-8 z-[9999] flex flex-col items-end';
                document.body.appendChild(container);
                return container;
            }
        };

        // Timezone conversion
        $(document).ready(function() {
          if (typeof moment !== 'undefined') {
            $('.local-date').each(function() {
              const timestamp = $(this).attr('data-timestamp');
              if (timestamp) {
                const m = moment(timestamp);
                if (m.isValid()) {
                  const localDate = m.local().format('DD/MM/YYYY HH:mm');
                  $(this).text(localDate);
                } else {
                  console.warn('Invalid timestamp for .local-date:', timestamp);
                }
              }
            });
          }
        });
    </script>
    
</body>
</html>
