    </div>

    <!-- TOOLTIP -->
    <div id="tooltip" class="fixed bg-gray-800 text-gray-100 text-xs px-2 py-1 rounded-md shadow-lg opacity-0 pointer-events-none transition-all duration-200 z-50"></div>

    <script>
        const sidebar = $("#sidebar");
        const body = $("body");
        const tooltip = $("#tooltip");

        // Toggle sidebar
        $("#sidebarToggle").on("click", function () {
            body.toggleClass("sidebar-collapsed");
        });

        // Toggle móvil
        $("#sidebarToggleMobile").on("click", function () {
            sidebar.removeClass("mobile-active");
        });

        $(document).on("click", function (e) {
            if (sidebar.hasClass("mobile-active") && !$(e.target).closest("#sidebar, #sidebarToggle").length) {
                sidebar.removeClass("mobile-active");
            }
        });

        // Tooltip
        $(".menu-item").hover(function (e) {
            if ($("body").hasClass("sidebar-collapsed")) {
                const text = $(this).data("tooltip");
                if (text) {
                    tooltip.text(text);
                    const rect = this.getBoundingClientRect();
                    tooltip.css({
                        top: rect.top + rect.height / 2 - 10,
                        left: rect.right + 10,
                        opacity: 1
                    });
                }
            }
        }, function () {
            tooltip.css("opacity", 0);
        });

        // Timezone conversion
        $(document).ready(function() {
          if (typeof moment !== 'undefined') {
            $('.local-date').each(function() {
              const timestamp = $(this).attr('data-timestamp');
              if (timestamp) {
                const m = moment(timestamp);
                if (m.isValid()) {
                  const localDate = m.local().format('DD/MM/YYYY HH:mm');
                  $(this).text(localDate);
                } else {
                  console.warn('Invalid timestamp for .local-date:', timestamp);
                }
              }
            });
          }
        });
    </script>
    
</body>
</html>
