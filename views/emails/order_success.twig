{% extends 'emails/layout.twig' %}

{% block content %}
    <h1>¡Gracias por tu pedido, {{ user_name }}!</h1>
    <p>Hemos recibido tu pedido y estamos procesándolo. Aquí tienes los detalles de tu compra:</p>
    
    <div style="background-color: #f9f9f9; padding: 15px; border-radius: 8px; margin: 20px 0;">
        <p style="margin: 0;"><strong>ID del Pedido:</strong> #{{ order_id }}</p>
        <p style="margin: 0;"><strong>Fecha:</strong> {{ "now"|date("d/m/Y H:i") }}</p>
    </div>

    <table width="100%" style="border-collapse: collapse;">
        <thead>
            <tr style="border-bottom: 2px solid #eeeeee;">
                <th align="left" style="padding: 10px 0;">Producto</th>
                <th align="right" style="padding: 10px 0;">Precio</th>
            </tr>
        </thead>
        <tbody>
            {% for item in items %}
            <tr style="border-bottom: 1px solid #eeeeee;">
                <td style="padding: 10px 0;">{{ item.name }}</td>
                <td align="right" style="padding: 10px 0;">{{ item.price }}€</td>
            </tr>
            {% endfor %}
        </tbody>
        <tfoot>
            <tr>
                <td align="right" style="padding: 20px 0 10px 0;"><strong>Total</strong></td>
                <td align="right" style="padding: 20px 0 10px 0;"><strong>{{ total }}€</strong></td>
            </tr>
        </tfoot>
    </table>
    
    <p style="text-align: center;">
        <a href="{{ url('/library') }}" class="button">Ver en mi biblioteca</a>
    </p>
    
    <div class="divider"></div>
    
    <p>Podrás encontrar tus juegos en la sección "Biblioteca" de tu perfil.</p>
{% endblock %}
