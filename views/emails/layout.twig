<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Gabarito:wght@400..900&family=Lexend:wght@100..900&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Lexend', sans-serif;
            background-color: #f4f7f6;
            color: #1a1a1a;
        }
        .wrapper {
            width: 100%;
            table-layout: fixed;
            background-color: #f4f7f6;
            padding-bottom: 40px;
        }
        .main {
            background-color: #ffffff;
            margin: 0 auto;
            width: 100%;
            max-width: 600px;
            border-spacing: 0;
            font-family: sans-serif;
            color: #1a1a1a;
        }
        .header {
            background-color: #1B2A49;
            padding: 20px;
            text-align: center;
        }
        .header img {
            max-width: 150px;
        }
        .content {
            padding: 40px 30px;
            line-height: 1.6;
            font-family: 'Lexend', sans-serif;
        }
        .content h1 {
            font-family: 'Gabarito', sans-serif;
            color: #1B2A49;
            font-size: 24px;
            margin-top: 0;
        }
        .footer {
            background-color: #0D1320;
            color: #ffffff;
            padding: 30px;
            text-align: center;
            font-size: 14px;
        }
        .footer a {
            color: #DEAB18;
            text-decoration: none;
        }
        .button {
            display: inline-block;
            padding: 12px 24px;
            background-color: #DEAB18;
            color: #ffffff;
            text-decoration: none;
            border-radius: 8px;
            font-weight: bold;
            font-family: 'Gabarito', sans-serif;
            margin-top: 20px;
        }
        .divider {
            border-top: 1px solid #eeeeee;
            margin: 20px 0;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <table class="main" width="100%">
            <!-- Header -->
            <tr>
                <td class="header">
                    <a href="{{ url('/') }}">
                        <img src="{{ asset('/assets/img/orion-logo.svg') }}" alt="Orion Logo">
                    </a>
                </td>
            </tr>

            <!-- Content -->
            <tr>
                <td class="content">
                    {% block content %}{% endblock %}
                </td>
            </tr>

            <!-- Footer -->
            <tr>
                <td class="footer">
                    <p>&copy; {{ "now"|date("Y") }} Orion. Todos los derechos reservados.</p>
                    <p>
                        <a href="{{ url('/legal/terms') }}">Términos de Servicio</a> | 
                        <a href="{{ url('/legal/privacy') }}">Privacidad</a>
                    </p>
                </td>
            </tr>
        </table>
    </div>
</body>
</html>
