{% extends 'layouts/base.twig' %}

{% block title %}Mis amigos - Orion{% endblock %}

{% block content %}
<section id="friends" class="py-20 min-h-screen">
  <div class="container mx-auto max-w-6xl">
    <div class="flex flex-col md:flex-row gap-8">
        
        <!-- Sidebar / Stats -->
        <div class="w-full md:w-1/4 bg-branddark shadow-lg rounded-xl p-6 h-fit sticky top-24">
            <h2 class="text-xl font-bold text-white mb-6 flex items-center">
                <i class="bi bi-people-fill mr-2 text-alt"></i> Amigos
            </h2>
            <div class="space-y-4">
                <div class="flex justify-between text-gray-400 text-sm">
                    <span>Total de amigos</span>
                    <span class="text-white font-semibold">{{ friends|length }}</span>
                </div>
                <div class="flex justify-between text-gray-400 text-sm">
                    <span>Solicitudes pendientes</span>
                    <span class="text-alt font-semibold">{{ pending_requests|length }}</span>
                </div>
            </div>
            <hr class="my-6 border-gray-700">
            <a href="/communities" class="w-full py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg text-center block transition duration-300 text-sm font-semibold">
                Buscar amigos
            </a>
        </div>

        <!-- Main Content -->
        <div class="w-full md:w-3/4 space-y-8">
            
            <!-- Pending Requests Section -->
            {% if pending_requests|length > 0 %}
            <div class="bg-branddark shadow-lg rounded-xl p-8">
                <h2 class="text-2xl font-bold text-white mb-6 flex items-center">
                    <span class="bg-alt w-2 h-8 rounded-full mr-3"></span>
                    Solicitudes pendientes
                </h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {% for requester in pending_requests %}
                    <div class="bg-gray-800/50 rounded-xl p-4 flex items-center justify-between group hover:bg-gray-800 transition duration-300 border border-transparent hover:border-alt/30">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-alt">
                                <img src="{{ profile_pic(requester) }}" alt="{{ requester.username }}" class="w-full h-full object-cover">
                            </div>
                            <div>
                                <h3 class="text-white font-semibold group-hover:text-alt transition">{{ requester.username }}</h3>
                                <p class="text-gray-500 text-xs italic">{{ user_handle(requester) }}</p>
                            </div>
                        </div>
                        <div class="flex gap-2">
                            <button onclick="friendAction('accept', {{ requester.id }})" class="p-2 bg-green-600/20 hover:bg-green-600 text-green-500 hover:text-white rounded-lg transition duration-300" title="Aceptar">
                                <i class="bi bi-check-lg"></i>
                            </button>
                            <button onclick="friendAction('decline', {{ requester.id }})" class="p-2 bg-red-600/20 hover:bg-red-600 text-red-500 hover:text-white rounded-lg transition duration-300" title="Rechazar">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <!-- Friends List Section -->
            <div class="bg-branddark shadow-lg rounded-xl p-8">
                <h2 class="text-2xl font-bold text-white mb-6 flex items-center">
                    <span class="bg-alt w-2 h-8 rounded-full mr-3"></span>
                    Mis Amigos
                </h2>

                {% if friends|length == 0 %}
                    <div class="text-center py-12">
                        <div class="text-6xl text-gray-700 mb-4">
                            <i class="bi bi-person-slash"></i>
                        </div>
                        <p class="text-gray-400">Aún no tienes amigos en Orion.</p>
                        <a href="/communities" class="text-alt hover:underline mt-2 inline-block">¡Empieza a conocer gente!</a>
                    </div>
                {% else %}
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                        {% for friend in friends %}
                        <div class="bg-gray-800/30 rounded-xl p-5 border border-gray-700/50 hover:border-alt/50 transition-all duration-300 group">
                            <div class="flex flex-col items-center text-center">
                                <div class="relative mb-4">
                                    <div class="w-20 h-20 rounded-full overflow-hidden border-2 border-gray-700 group-hover:border-alt transition duration-500">
                                        <img src="{{ profile_pic(friend) }}" alt="{{ friend.username }}" class="w-full h-full object-cover">
                                    </div>
                                    <div class="absolute bottom-0 right-0 w-5 h-5 bg-green-500 border-4 border-branddark rounded-full"></div>
                                </div>
                                <h3 class="text-white font-bold text-lg group-hover:text-alt transition">{{ friend.username }}</h3>
                                <p class="text-gray-500 text-sm mb-4">{{ user_handle(friend) }}</p>
                                
                                <div class="flex w-full gap-2 mt-2">
                                    <a href="/profile/{{ friend.id }}" class="flex-1 py-1.5 bg-gray-700 hover:bg-gray-600 text-white rounded-lg text-xs font-semibold transition">
                                        Perfil
                                    </a>
                                    <button onclick="friendAction('remove', {{ friend.id }})" class="px-3 py-1.5 bg-red-600/10 hover:bg-red-600 text-red-500 hover:text-white rounded-lg text-xs font-semibold transition">
                                        <i class="bi bi-person-x-fill"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

        </div>
    </div>
  </div>
</section>
{% endblock %}

{% block scripts %}
<script>
    function friendAction(action, userId) {
        let url = '';
        switch(action) {
            case 'accept': url = `/api/friends/accept/${userId}`; break;
            case 'decline': url = `/api/friends/decline/${userId}`; break;
            case 'remove': 
                if (!confirm('¿Estás seguro de que quieres eliminar a este amigo?')) return;
                url = `/api/friends/remove/${userId}`; 
                break;
        }

        $.ajax({
            url: url,
            method: 'POST',
            success: function(response) {
                location.reload();
            },
            error: function(error) {
                console.error('Error in friend action:', error);
                alert('Hubo un error al procesar la acción.');
            }
        });
    }
</script>
{% endblock %}
