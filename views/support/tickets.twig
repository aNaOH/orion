{% extends 'layouts/base.twig' %}

{% block title %}Mis Solicitudes - Orion{% endblock %}

{% block content %}
<div class="py-12 animate__animated animate__fadeIn max-w-5xl mx-auto">
    <div class="mb-10 flex flex-col md:flex-row md:items-center md:justify-between space-y-6 md:space-y-0">
        <div>
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-3">
                    <li class="inline-flex items-center">
                        <a href="/support" class="text-gray-400 hover:text-white transition-colors flex items-center">
                            <i class="bi bi-house-door-fill mr-2"></i>
                            Soporte
                        </a>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="bi bi-chevron-right text-gray-600 text-xs mx-2"></i>
                            <span class="text-gray-200 font-semibold">Mis Solicitudes</span>
                        </div>
                    </li>
                </ol>
            </nav>
            <h1 class="text-4xl font-bold text-white mb-2">Mis Solicitudes</h1>
            <p class="text-gray-400">Historial de tus reportes, apelaciones y consultas al equipo.</p>
        </div>
        
        <div class="flex space-x-3">
            <a href="/support/faq" class="px-5 py-2.5 bg-branddark/60 border border-white/10 rounded-lg text-sm font-semibold text-gray-300 hover:bg-branddark/80 transition-colors">
                Ver FAQ
            </a>
            {# You could add a "New Ticket" button here if there was a general ticket system #}
        </div>
    </div>

    {% if tickets is empty %}
        <div class="bg-branddark/40 border border-dashed border-white/10 rounded-3xl p-20 text-center">
            <div class="w-20 h-20 bg-gray-500/10 rounded-full flex items-center justify-center mx-auto mb-6">
                <i class="bi bi-ticket-detailed text-4xl text-gray-500"></i>
            </div>
            <h3 class="text-2xl font-bold text-gray-200 mb-2">No tienes solicitudes</h3>
            <p class="text-gray-400 max-w-sm mx-auto">Aún no has creado ningún reporte o apelación. Todo parece estar en orden.</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 gap-6">
            {% for ticket in tickets %}
                <div class="bg-branddark/50 border border-white/5 rounded-2xl p-6 hover:border-white/10 transition-colors">
                    <div class="flex flex-col md:flex-row md:items-center justify-between">
                        <div class="flex items-start space-x-4 mb-4 md:mb-0">
                            <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 
                                {% if ticket.type == 'report_user' %}bg-red-500/10 text-red-500
                                {% elseif ticket.type == 'appeal' %}bg-alt/10 text-alt
                                {% else %}bg-blue-500/10 text-blue-500{% endif %}">
                                <i class="bi {% if ticket.type == 'report_user' %}bi-person-x
                                    {% elseif ticket.type == 'appeal' %}bi-gavel
                                    {% else %}bi-info-circle{% endif %} text-2xl"></i>
                            </div>
                            <div>
                                <div class="flex items-center space-x-3 mb-1">
                                    <span class="text-lg font-bold text-gray-100">
                                        {% if ticket.type == 'report_user' %}Reporte de Usuario
                                        {% elseif ticket.type == 'appeal' %}Apelación de Sanción
                                        {% else %}Consulta General{% endif %}
                                    </span>
                                    <span class="px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider
                                        {% if ticket.status == 0 %}bg-amber-500/10 text-amber-500
                                        {% elseif ticket.status == 1 %}bg-emerald-500/10 text-emerald-500
                                        {% elseif ticket.status == 2 %}bg-red-500/10 text-red-500{% endif %}">
                                        {% if ticket.status == 0 %}Pendiente
                                        {% elseif ticket.status == 1 %}Aceptado
                                        {% elseif ticket.status == 2 %}Rechazado{% endif %}
                                    </span>
                                </div>
                                <div class="text-sm text-gray-500">
                                    Ticket #{{ ticket.id }} &bull; Creado el <span class="local-date" data-timestamp="{{ ticket.created_at|date('c') }}">{{ ticket.created_at|date('d/m/Y H:i') }}</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="text-right">
                            <button onclick="toggleDetails({{ ticket.id }})" class="px-4 py-2 bg-white/5 hover:bg-white/10 rounded-lg text-sm font-medium text-gray-300 transition-colors">
                                Ver Detalles <i class="bi bi-chevron-down ml-1"></i>
                            </button>
                        </div>
                    </div>
                    
                    <!-- Hidden Details Section -->
                    <div id="details-{{ ticket.id }}" class="hidden mt-6 pt-6 border-t border-white/5">
                        <div class="bg-black/20 rounded-xl p-5 mb-4">
                            <h4 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Comentario de Administración</h4>
                            {% if ticket.admin_comment %}
                                <p class="text-gray-300 leading-relaxed italic">"{{ ticket.admin_comment }}"</p>
                            {% else %}
                                <p class="text-gray-500 italic">No hay comentarios todavía. El equipo está revisando tu solicitud.</p>
                            {% endif %}
                        </div>
                        
                        <div class="flex items-center justify-between text-xs text-gray-600">
                            <span>Última actualización: <span class="local-date" data-timestamp="{{ ticket.updated_at|date('c') }}">{{ ticket.updated_at|date('d/m/Y H:i') }}</span></span>
                            <span class="flex items-center"><i class="bi bi-clock-history mr-1"></i> Tiempo estimado: 24-48h</span>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
<script>
    function toggleDetails(id) {
        const details = $('#details-' + id);
        const btn = details.prev().find('button i');
        
        details.slideToggle(300, function() {
            $(this).toggleClass('hidden');
        });
        btn.toggleClass('bi-chevron-down bi-chevron-up');
    }
</script>
{% endblock %}
