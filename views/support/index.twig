{% extends 'layouts/base.twig' %}

{% block title %}Centro de Soporte - Orion{% endblock %}

{% block content %}
<div class="py-12 animate__animated animate__fadeIn">
    <!-- Hero Section -->
    <div class="text-center mb-16">
        <h1 class="text-5xl font-extrabold text-white mb-4">¿En qué podemos ayudarte?</h1>
        <p class="text-gray-400 text-xl max-w-2xl mx-auto">
            Explora nuestra base de conocimientos o contacta con nuestro equipo para resolver tus dudas.
        </p>
    </div>

    <!-- Quick Links Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-20">
        <!-- FAQ Card -->
        <a href="/support/faq" class="group bg-branddark/50 p-8 rounded-2xl border border-white/5 hover:border-alt/30 transition-all duration-300 hover:shadow-2xl hover:shadow-alt/10 transform hover:-translate-y-1">
            <div class="w-14 h-14 bg-alt/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-alt/20 transition-colors">
                <i class="bi bi-question-circle text-2xl text-alt"></i>
            </div>
            <h3 class="text-2xl font-bold text-white mb-3">Preguntas Frecuentes</h3>
            <p class="text-gray-400 leading-relaxed">
                Encuentra respuestas rápidas a las dudas más comunes sobre el juego y tu cuenta.
            </p>
        </a>

        <!-- My Tickets Card -->
        <a href="/support/tickets" class="group bg-branddark/50 p-8 rounded-2xl border border-white/5 hover:border-alt-blue/30 transition-all duration-300 hover:shadow-2xl hover:shadow-alt-blue/10 transform hover:-translate-y-1">
            <div class="w-14 h-14 bg-alt-blue/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-alt-blue/20 transition-colors">
                <i class="bi bi-ticket-perforated text-2xl text-alt-blue"></i>
            </div>
            <h3 class="text-2xl font-bold text-white mb-3">Mis Solicitudes</h3>
            <p class="text-gray-400 leading-relaxed">
                Consulta el estado de tus reportes, apelaciones y consultas anteriores.
            </p>
        </a>

        <!-- Safety Card -->
        <a href="/support/safety" class="group bg-branddark/50 p-8 rounded-2xl border border-white/5 hover:border-red-500/30 transition-all duration-300 hover:shadow-2xl hover:shadow-red-500/10 transform hover:-translate-y-1">
            <div class="w-14 h-14 bg-red-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-red-500/20 transition-colors">
                <i class="bi bi-shield-check text-2xl text-red-500"></i>
            </div>
            <h3 class="text-2xl font-bold text-white mb-3">Seguridad y Reportes</h3>
            <p class="text-gray-400 leading-relaxed">
                Aprende cómo mantener tu cuenta segura y cómo reportar comportamientos inadecuados.
            </p>
        </a>

        <!-- Create Ticket Card -->
        <a href="/support/create" class="group bg-branddark/50 p-8 rounded-2xl border border-white/5 hover:border-emerald-500/30 transition-all duration-300 hover:shadow-2xl hover:shadow-emerald-500/10 transform hover:-translate-y-1">
            <div class="w-14 h-14 bg-emerald-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-emerald-500/20 transition-colors">
                <i class="bi bi-chat-dots text-2xl text-emerald-500"></i>
            </div>
            <h3 class="text-2xl font-bold text-white mb-3">Contactar Soporte</h3>
            <p class="text-gray-400 leading-relaxed">
                ¿No encuentras lo que buscas? Abre un ticket y nuestro equipo te ayudará personalmente.
            </p>
        </a>
    </div>

    <!-- Other Resources -->
    <div class="bg-branddark/30 rounded-3xl p-10 border border-white/5">
        <h2 class="text-3xl font-bold text-white mb-8 text-center">Otros recursos</h2>
        <div class="flex flex-wrap justify-center gap-6">
            {% if user and user.getActiveSuspension %}
            <a href="/support/appeal" class="flex items-center p-4 rounded-xl bg-brand/40 border border-white/5 hover:bg-brand/60 transition-colors min-w-[240px]">
                <i class="bi bi-gavel text-alt mr-4 text-xl"></i>
                <span class="text-gray-200 font-medium">Apelar sanción</span>
            </a>
            {% endif %}
            <a href="/legal/terms" class="flex items-center p-4 rounded-xl bg-brand/40 border border-white/5 hover:bg-brand/60 transition-colors min-w-[240px]">
                <i class="bi bi-file-earmark-text text-gray-400 mr-4 text-xl"></i>
                <span class="text-gray-200 font-medium">Términos de Servicio</span>
            </a>
            <a href="/legal/privacy" class="flex items-center p-4 rounded-xl bg-brand/40 border border-white/5 hover:bg-brand/60 transition-colors min-w-[240px]">
                <i class="bi bi-lock text-gray-400 mr-4 text-xl"></i>
                <span class="text-gray-200 font-medium">Privacidad</span>
            </a>
            <a href="https://discord.gg/togetheronorion" class="flex items-center p-4 rounded-xl bg-brand/40 border border-white/5 hover:bg-brand/60 transition-colors min-w-[240px]">
                <i class="bi bi-discord text-[#5865F2] mr-4 text-xl"></i>
                <span class="text-gray-200 font-medium">Discord Oficial</span>
            </a>
        </div>
    </div>
</div>
{% endblock %}
